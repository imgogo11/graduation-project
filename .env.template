# Application/runtime configuration template.
# The existing root .env can continue to serve as a machine checklist.

APP_ENV=development
DATA_ROOT=./data
RAW_DATA_DIR=./data/raw
PROCESSED_DATA_DIR=./data/processed

# Stock ingestion
STOCK_DEFAULT_SYMBOLS=000001,600519,300750
STOCK_START_DATE=20240406
STOCK_END_DATE=20260406
STOCK_ADJUST=qfq
TUSHARE_TOKEN=

# E-commerce datasets
OLIST_DATASET_DIR=./data/raw/ecommerce/olist
HF_ORDERS_DATASET=millat/e-commerce-orders
HF_PRODUCT_DATASET=erayalp/amazon-product-dataset

# Demo crawler
WEBSCRAPER_DEMO_URL=https://webscraper.io/test-sites/e-commerce/static
WEBSCRAPER_CATEGORY=computers
WEBSCRAPER_MAX_PAGES=3
WEBSCRAPER_SLEEP_SECONDS=1.0
